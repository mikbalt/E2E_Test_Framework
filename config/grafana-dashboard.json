{
  "dashboard": {
    "title": "HSM Test Results Dashboard",
    "tags": ["hsm", "testing", "automation"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Test Pass Rate",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "hsm_suite_pass_rate{suite=\"hsm\"}",
            "legendFormat": "Pass Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.9 }
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "title": "Suite Duration (seconds)",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "hsm_suite_duration_seconds{suite=\"hsm\"}",
            "legendFormat": "Duration"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Last Run",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "hsm_last_run_timestamp{suite=\"hsm\"} * 1000",
            "legendFormat": "Last Run"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "dateTimeFromNow" }
        }
      },
      {
        "title": "Tests Passed vs Failed (over time)",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 18, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(hsm_tests_total{status=\"passed\"}) by (suite)",
            "legendFormat": "Passed"
          },
          {
            "expr": "sum(hsm_tests_total{status=\"failed\"}) by (suite)",
            "legendFormat": "Failed"
          }
        ]
      },
      {
        "title": "Test Duration Distribution",
        "type": "histogram",
        "gridPos": { "h": 10, "w": 18, "x": 0, "y": 18 },
        "targets": [
          {
            "expr": "hsm_test_duration_seconds_bucket",
            "legendFormat": "{{test_name}}"
          }
        ]
      }
    ],
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" }
  },
  "_comment": "Import this dashboard via Grafana UI > Dashboards > Import > Upload JSON. Requires Prometheus datasource configured."
}
