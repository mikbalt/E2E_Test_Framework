/*
 * PKCS#11 Test Suite - Jenkins Pipeline
 *
 * This pipeline:
 * 1. Builds source code (Java, Go, GTest/C++) on each platform
 * 2. Runs tests on Windows and Linux agents in parallel
 * 3. Collects evidence (logs, screenshots, GTest XML reports)
 * 4. Generates Allure report with all evidence attached
 *
 * Prerequisites:
 *   - Jenkins agents labeled 'windows' and 'linux'
 *   - Python 3.9+ on both agents
 *   - Java SDK (for Java tests), Go (for Go tests), Make/GCC (for GTest)
 *   - Allure Jenkins Plugin installed
 */

pipeline {
    agent none

    parameters {
        choice(
            name: 'TEST_SUITE',
            choices: ['all', 'smoke', 'regression', 'java', 'cpp', 'go_test', 'gtest'],
            description: 'Which test suite to run'
        )
        booleanParam(
            name: 'RUN_WINDOWS',
            defaultValue: true,
            description: 'Run tests on Windows agent'
        )
        booleanParam(
            name: 'RUN_LINUX',
            defaultValue: true,
            description: 'Run tests on Linux agent'
        )
        booleanParam(
            name: 'SKIP_BUILD',
            defaultValue: false,
            description: 'Skip build step (use pre-built binaries)'
        )
    }

    environment {
        PIP_NO_CACHE_DIR = '1'
    }

    stages {

        stage('Test') {
            parallel {

                // ============================================================
                // WINDOWS
                // ============================================================
                stage('Windows') {
                    when { expression { params.RUN_WINDOWS } }
                    agent { label 'windows' }
                    stages {

                        stage('Setup (Win)') {
                            steps {
                                bat '''
                                    py -3 -m venv venv
                                    call venv\\Scripts\\activate.bat
                                    pip install --upgrade pip
                                    pip install -r requirements.txt
                                '''
                            }
                        }

                        stage('Build (Win)') {
                            when { expression { !params.SKIP_BUILD } }
                            steps {
                                bat '''
                                    call venv\\Scripts\\activate.bat
                                    scripts\\build.bat
                                '''
                            }
                        }

                        stage('Run Tests (Win)') {
                            steps {
                                bat """
                                    call venv\\Scripts\\activate.bat
                                    set BUILD_SKIP=1
                                    python -m pytest -m "${params.TEST_SUITE == 'all' ? '' : params.TEST_SUITE}" ^
                                        -v --tb=short ^
                                        --alluredir=evidence\\allure-results ^
                                        --junitxml=evidence\\junit-results.xml ^
                                        --timeout=120
                                """
                            }
                            post {
                                always {
                                    junit allowEmptyResults: true,
                                         testResults: 'evidence/junit-results.xml'

                                    // Archive all evidence (logs, screenshots, GTest XML)
                                    archiveArtifacts artifacts: 'evidence/**/*',
                                                     allowEmptyArchive: true
                                    archiveArtifacts artifacts: 'logs/**/*',
                                                     allowEmptyArchive: true

                                    stash includes: 'evidence/allure-results/**',
                                          name: 'windows-allure',
                                          allowEmpty: true
                                }
                            }
                        }
                    }
                }

                // ============================================================
                // LINUX
                // ============================================================
                stage('Linux') {
                    when { expression { params.RUN_LINUX } }
                    agent { label 'linux' }
                    stages {

                        stage('Setup (Linux)') {
                            steps {
                                sh '''
                                    python3 -m venv venv
                                    . venv/bin/activate
                                    pip install --upgrade pip
                                    pip install -r requirements.txt
                                '''
                            }
                        }

                        stage('Build (Linux)') {
                            when { expression { !params.SKIP_BUILD } }
                            steps {
                                sh '''
                                    . venv/bin/activate
                                    chmod +x scripts/build.sh
                                    ./scripts/build.sh
                                '''
                            }
                        }

                        stage('Run Tests (Linux)') {
                            steps {
                                sh """
                                    . venv/bin/activate
                                    export BUILD_SKIP=1
                                    python3 -m pytest -m "${params.TEST_SUITE == 'all' ? '' : params.TEST_SUITE}" \
                                        -v --tb=short \
                                        --alluredir=evidence/allure-results \
                                        --junitxml=evidence/junit-results.xml \
                                        --timeout=120
                                """
                            }
                            post {
                                always {
                                    junit allowEmptyResults: true,
                                         testResults: 'evidence/junit-results.xml'

                                    archiveArtifacts artifacts: 'evidence/**/*',
                                                     allowEmptyArchive: true
                                    archiveArtifacts artifacts: 'logs/**/*',
                                                     allowEmptyArchive: true

                                    stash includes: 'evidence/allure-results/**',
                                          name: 'linux-allure',
                                          allowEmpty: true
                                }
                            }
                        }
                    }
                }
            }
        }

        // ============================================================
        // Allure Report (merge results from both platforms)
        // ============================================================
        stage('Allure Report') {
            agent { label 'linux || windows' }
            steps {
                // Unstash results from both platforms
                script {
                    try { unstash 'windows-allure' } catch (e) { echo "No Windows results" }
                    try { unstash 'linux-allure' } catch (e) { echo "No Linux results" }
                }

                // Generate Allure report
                allure includeProperties: false,
                       jdk: '',
                       results: [[path: 'evidence/allure-results']]
            }
        }
    }

    post {
        success {
            echo "PKCS#11 Test Suite: ALL PASSED"
        }
        failure {
            echo "PKCS#11 Test Suite: SOME TESTS FAILED — check Allure report for details"
        }
        always {
            echo "Pipeline complete. Suite: ${params.TEST_SUITE}"
        }
    }
}
