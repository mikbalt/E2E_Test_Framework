# =============================================================================
# Ankole Framework - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is safe to commit.

# --- Workspace Applications ---
WORKSPACE_WEB_URL=http://localhost:5000
WORKSPACE_API_URL=http://localhost:8000

# --- Database (used by sample_apps) ---
DATABASE_URL=postgresql://ankole:ankole@localhost:5432/ankole

# --- Kiwi TCMS [optional] ---
# TCMS_API_URL=https://kiwi.yourcompany.com/xml-rpc/
# TCMS_USERNAME=your_user
# TCMS_PASSWORD=your_pass
# KIWI_PLAN_ID=1
# KIWI_BUILD_ID=1

# --- Prometheus Pushgateway [optional] ---
PUSHGATEWAY_URL=http://localhost:9091

# --- Loki [optional] ---
LOKI_URL=http://localhost:3100

# --- Test Credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
