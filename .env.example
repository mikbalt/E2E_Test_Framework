# =============================================================================
# HSM Test Framework — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored; .env.example is safe to commit.
#
# If a variable is not set, the default from config/settings.yaml is used.
# Variables marked [required] must be set for their feature to work.

# --- HSM Target (E-Admin connection + health checks) [required] ---
HSM_IP=10.66.1.10
HSM_PORT=52000
E_ADMIN_PATH=C:\SPHERE_HSM\Admin Application\AdminApp.exe
E_ADMIN_APP_LOGS=C:\SPHERE_HSM\Admin Application\AppLogs

# --- Kiwi TCMS [required if using --kiwi-run-id or --kiwi-create-run] ---
TCMS_API_URL=https://kiwi.yourcompany.com/xml-rpc/
TCMS_USERNAME=your_user
TCMS_PASSWORD=your_pass
# KIWI_PLAN_ID=1        # Optional — only needed for --kiwi-create-run
# KIWI_BUILD_ID=1       # Optional — only needed for --kiwi-create-run

# --- HSM PIN [optional] ---
# Consumed directly by PKCS#11 CLI tools via the env: prefix
# (e.g. pkcs11-tool --pin env:HSM_PIN), not read by framework code.
HSM_PIN=your_pin_here

# --- Prometheus Pushgateway [optional, for Grafana metrics] ---
PUSHGATEWAY_URL=http://localhost:9091
